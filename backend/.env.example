# --- Database Configuration ---
# Mode: "postgres" (default) or "supabase"
DATABASE_MODE=postgres

# Option 1: Local Postgres (Default)
DATABASE_URL=postgresql://postgres:password@localhost:5432/spark

# Option 2: Supabase
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Caching ---
REDIS_URL=redis://localhost:6379

# --- LLM Gateway Configuration ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
LLM_BASE_URL=
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Provider-specific keys (alternative to LLM_API_KEY)
OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...
# LITELLM_API_KEY=sk-...
# LLMGW_API_KEY=
# LLMGW_BASE_URL=
# CUSTOM_LLM_API_KEY=
# CUSTOM_LLM_BASE_URL=

# Fallback (optional)
# LLM_FALLBACK_PROVIDER=
# LLM_FALLBACK_MODEL=
# LLM_FALLBACK_API_KEY=
# LLM_FALLBACK_BASE_URL=

# OpenRouter-specific (optional)
# OPENROUTER_SITE_URL=
# OPENROUTER_APP_NAME=spark-engine

# --- Application ---
ENVIRONMENT=development
LOG_LEVEL=INFO
