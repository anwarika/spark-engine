# --- Database Configuration ---
# Mode: "postgres" (default) or "supabase"
DATABASE_MODE=postgres

# Option 1: Local Postgres (Default)
DATABASE_URL=postgresql://postgres:password@localhost:5432/spark

# Option 2: Supabase
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Caching ---
REDIS_URL=redis://localhost:6379

# --- LLM Gateway Configuration (v3) ---
LLM_PROVIDER=openai                    # openai | openrouter | litellm | llmgw | custom
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=                           # Or use provider-specific env vars below
LLM_BASE_URL=                          # Override for custom/llmgw endpoints
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# Provider-specific keys (alternative to LLM_API_KEY)
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...
LITELLM_API_KEY=sk-...
LLMGW_API_KEY=
LLMGW_BASE_URL=                        # Bloomberg LLM Gateway URL

# Fallback (optional)
LLM_FALLBACK_PROVIDER=
LLM_FALLBACK_MODEL=
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_BASE_URL=

# OpenRouter-specific (optional)
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=spark-engine

# Legacy: Anthropic / OpenRouter (for llm_providers.py)
# ANTHROPIC_API_KEY=sk-ant-...

# --- Application ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Frontend ---
VITE_API_URL=http://localhost:8000/api
